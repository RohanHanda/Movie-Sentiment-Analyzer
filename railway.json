{
  "services": {
    "backend": {
      "root": ".",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "gunicorn backend.app:app",
      "envVars": [
        {
          "key": "PYTHONUNBUFFERED",
          "value": "1"
        }
      ]
    },
    "frontend": {
      "root": "frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npx serve -s build -l 3000"
    }
  }
}
