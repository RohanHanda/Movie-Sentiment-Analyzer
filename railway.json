{
  "services": {
    "backend": {
      "root": ".",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "cd backend && gunicorn --bind 0.0.0.0:$PORT app:app",
      "envVars": [
        {
          "key": "PYTHONUNBUFFERED",
          "value": "1"
        }
      ]
    }
  }
}
