{
  "services": {
    "backend": {
      "root": ".",
      "buildCommand": "pip install -r requirements.txt && cp backend/*.joblib . || true",
      "startCommand": "gunicorn --bind 0.0.0.0:$PORT backend.app:app --chdir .",
      "envVars": [
        {
          "key": "PYTHONUNBUFFERED",
          "value": "1"
        }
      ]
    }
  }
}
